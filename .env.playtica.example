BUNNY_APP_NAME="Bunny App"
BUNNY_HOST=127.0.0.1
BUNNY_PORT=8000

# Server-friendly runtime paths.
BUNNY_WHISPER_CPP_BINARY=/home/scshin/.local/bin/whisper-cli
BUNNY_MODEL_ROOT=/home/scshin/projects/bunny-app/models

BUNNY_ASR_ENGINE=whisper_cpp
BUNNY_WHISPER_MODEL_PATH=/home/scshin/projects/bunny-app/models/whisper/ggml-large-v3-turbo.bin
BUNNY_WHISPER_LANGUAGE=auto
BUNNY_WHISPER_CPP_NO_GPU=true
BUNNY_WHISPER_CPP_USE_VAD=true
BUNNY_WHISPER_VAD_MODEL_PATH=/home/scshin/projects/bunny-app/models/whisper/ggml-silero-v6.2.0.bin
BUNNY_WHISPER_CPP_SUPPRESS_NON_SPEECH=true
BUNNY_WHISPER_CPP_NO_FALLBACK=false
BUNNY_WHISPER_THREADS=4
BUNNY_WHISPER_PROCESSORS=1
BUNNY_WHISPER_PARTIAL_BEAM_SIZE=3
BUNNY_WHISPER_FINAL_BEAM_SIZE=7

BUNNY_VAD_ENABLED=true
BUNNY_VAD_ENERGY_THRESHOLD=0.015
BUNNY_VAD_SILENCE_MS=550
BUNNY_VAD_MIN_SPEECH_MS=260
BUNNY_VAD_PREROLL_MS=420
BUNNY_UTTERANCE_MAX_MS=8000
BUNNY_SEGMENT_EMIT_MS=650
BUNNY_SEGMENT_EMIT_BYTES=16000
BUNNY_PARTIAL_PREVIEW_MS=2800

BUNNY_TRANSLATION_ENGINE=nllb_ct2
BUNNY_TRANSLATION_MODEL_PATH=/home/scshin/projects/bunny-app/models/nllb-200-distilled-600M-ct2
BUNNY_TRANSLATION_TOKENIZER_PATH=/home/scshin/projects/bunny-app/models/nllb-200-distilled-600M-ct2
BUNNY_TRANSLATION_DEVICE=cpu
BUNNY_TRANSLATION_COMPUTE_TYPE=int8
BUNNY_TRANSLATION_INTER_THREADS=1
BUNNY_TRANSLATION_INTRA_THREADS=0
BUNNY_TRANSLATION_TARGETS='["ko","es"]'

BUNNY_LLM_POSTEDIT_ENABLED=false
BUNNY_LLM_POSTEDIT_BASE_URL=
BUNNY_LLM_POSTEDIT_API_KEY=
BUNNY_LLM_POSTEDIT_MODEL=
BUNNY_LLM_POSTEDIT_TIMEOUT_S=8
BUNNY_LLM_POSTEDIT_HISTORY_TURNS=4
BUNNY_LLM_POSTEDIT_SCOPE=final

BUNNY_ROOM_STORE_BACKEND=sqlite
BUNNY_ROOM_STORE_PATH=/home/scshin/projects/bunny-app/data/bunny_app.sqlite3
BUNNY_ROOM_MAX_PARTICIPANTS=5
BUNNY_ROOM_TTL_MINUTES=1440
BUNNY_ROOM_CLEANUP_INTERVAL_SECONDS=300

# Public tunnel settings.
BUNNY_CLOUDFLARE_TUNNEL_BIN=/home/scshin/.local/bin/cloudflared
BUNNY_CLOUDFLARE_TUNNEL_TOKEN_FILE=/home/scshin/.config/bunny-app/cloudflare.token
